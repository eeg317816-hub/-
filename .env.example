# ============================================================
# 全职高手测手速 · 环境变量示例（勿提交真实密码）
# 复制为 .env.local / .env.development / .env.test / .env.production
# ============================================================

# development | test | production
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# 数据库（每套环境必须独立库）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/qzgs_apm_game_dev?schema=public

# 服务
PORT=3000
HOSTNAME=0.0.0.0

# 对外访问根地址（同域部署可留空；跨域时填完整 origin）
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 管理后台 JWT（生产务必随机长串）
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# 首次 seed 管理员（仅初始化；勿写死在业务代码）
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=admin123

# 终端 / 刷卡
# development|test 显示手工输入；production 仅楔形键盘刷卡
NEXT_PUBLIC_ENABLE_DEV_CARD_INPUT=true
# 登录后未开局会话过期（秒）
SESSION_IDLE_TTL_SECONDS=120
# 心跳间隔提示（前端用）
NEXT_PUBLIC_HEARTBEAT_INTERVAL_MS=20000
# 活动标识
NEXT_PUBLIC_GAME_ID=qzgs-apm-2026

# 域名示意（文档用，运行时可忽略）
# development:  http://localhost:3000
# test:         https://apm-test.example.com
# production:   http://apm.local  或 http://192.168.x.x:3000
